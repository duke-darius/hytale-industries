$C = "../Common.ui";

Group {
  Anchor: (Width: 670, Height: 820);

  $C.@Container {
    Anchor: (Full: 0);

    #Title {
      Group {
        $C.@Title #TitleText {
          @Text = "Terminal";
        }
      }
    }

    #Content {
      LayoutMode: Top;
      Padding: (Left: 12, Right: 12, Top: 8, Bottom: 8);

      // Storage summary
      Group #HeaderRow {
        LayoutMode: Left;
        Anchor: (Height: 22, Bottom: 4);

        Label #StorageLabel {
          Style: (
            FontSize: 11,
            TextColor: #7f93a9
          );
        }
      }

      // Network items grid (scrollable)
      Group #NetworkGrid {
        LayoutMode: Top;
        FlexWeight: 1;
        Anchor: (Bottom: 8);
        Background: #05070d;

        Group {
          Anchor: (Height: 1, Bottom: 1);
          Background: #1e2634;
        }

        Group #NetworkScrollbox {
          LayoutMode: TopScrolling;
          ScrollbarStyle: $C.@DefaultScrollbarStyle;
          Anchor: (Top: 4, Bottom: 4, Left: 4, Right: 4);

          Group #NetworkContainer {
            LayoutMode: LeftCenterWrap;
            Anchor: (Width: 630);
          }
        }
      }

      // Separator
      Group {
        Anchor: (Height: 1, Bottom: 6);
        Background: #1e2634;
      }

      // Inventory header
      Group {
        Anchor: (Height: 20, Bottom: 4);
        Label {
          Text: "Inventory";
          Style: (
            FontSize: 12,
            TextColor: #8ea0b8
          );
        }
      }

      // Player inventory grid
      Group #InventorySection {
        Background: #05070d;
        Anchor: (Height: 360);

        Group {
          Anchor: (Height: 1, Bottom: 1);
          Background: #1e2634;
        }

        Group #InventoryScrollbox {
          LayoutMode: TopScrolling;
          ScrollbarStyle: $C.@DefaultScrollbarStyle;
          Anchor: (Top: 4, Bottom: 4, Left: 4, Right: 4);

          Group #InventoryContainer {
            LayoutMode: LeftCenterWrap;
            Anchor: (Width: 630);
          }
        }
      }
    }
  }
}
